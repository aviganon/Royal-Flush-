# העתק לקובץ .env.local (בשורש הפרויקט) והשלם את השדות הריקים מהקונסול.
# פרויקט: royal-flush-32cbb
# הגדרות כלליות: https://console.firebase.google.com/project/royal-flush-32cbb/settings/general

# --- Firebase Web ---
# Project settings → Your apps → Web → SDK setup (העתק את הערכים מה-snippet)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# אלה קבועים לפרויקט שלך (אפשר להשאיר כמו שכתוב):
NEXT_PUBLIC_FIREBASE_PROJECT_ID=royal-flush-32cbb
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=royal-flush-32cbb.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=royal-flush-32cbb.appspot.com

# --- Firebase Admin (חובה ל-bootstrap של משתמשים + Stripe webhook + אימות Socket) ---
# Project settings → Service accounts → Generate new private key
# הדבק את כל ה-JSON בשורה אחת (בלי שבירות שורה). private_key יכול להישאר עם \n
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- כתובת האתר ---
# מקומי:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# ייצור (Vercel): אם לא מגדירים — Next משתמש ב-VERCEL_URL אוטומטית.
# מומלץ במפורש ל-Stripe / קישורים יציבים:
# NEXT_PUBLIC_APP_URL=https://royal-flush-poker.vercel.app

NEXT_PUBLIC_POKER_SOCKET_URL=http://localhost:4000

# --- סנכרון צ'יפים אחרי יד (Next API ← שרת Socket) ---
# אותו ערך ב-Vercel ובשרת הפוקר. בייצור חובה; בפיתוח אופציונלי (ללא secret — רק dev)
# POKER_SERVER_SECRET=החלף_במחרוזת_ארוכה_אקראית

# --- Stripe (אופציונלי עד שמפעילים תשלומים) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# אחרי פריסה לייצור הוסיפו את דומיין האתר:
# POKER_CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://royal-flush-poker.vercel.app
